NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
ALLOWED_EMAILS=

# ChatGPT/Codex subscription backend (OAuth — NOT an OPENAI_API_KEY).
# Each user links their OWN OpenAI account via /api/codex/login; their LLM
# calls route to chatgpt.com/backend-api/codex/responses on their own
# subscription. Per-user tokens are stored in the Supabase codex_credentials
# table (keyed by user_id), so Supabase must be configured.
# Defaults below match the Codex CLI client; override only if needed.
CODEX_CLIENT_ID=app_EMoamEEZ73f0CkXaXp7hrann
CODEX_ISSUER=https://auth.openai.com
CODEX_BACKEND_URL=https://chatgpt.com/backend-api/codex
# The Codex public client only allows this exact redirect URI, so the app runs
# on port 1455 (npm run dev). Do not change unless you use your own client.
CODEX_REDIRECT_URI=http://localhost:1455/auth/callback

ACTOR_MODEL=gpt-5.4-mini
REVIEWER_MODEL=gpt-5.4-mini
TEACHER_MODEL=gpt-5.4-mini
